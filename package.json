{
  "name": "pdr-automation",
  "version": "2.0.0",
  "description": "PDR-AUTOMATION — Visual QA Automation Runner powered by Playwright",
  "main": "./out/main/index.js",
  "author": "PDR QA Team",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/patrick-hand": "^5.2.8",
    "docx": "^8.5.0",
    "playwright": "^1.45.0",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.3.4"
  },
  "build": {
    "appId": "com.pdr-automation",
    "productName": "PDR-AUTOMATION",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "data/",
        "to": "data/"
      }
    ]
  }
}
